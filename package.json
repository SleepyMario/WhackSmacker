{
  "name": "whacksmacker",
  "version": "0.0.1",
  "description": "Native terminal learning workflows for WhackSmacker content packages.",
  "private": true,
  "license": "GPL-3.0-or-later",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "whacksmacker": "dist/main.js",
    "wsm": "dist/main.js"
  },
  "files": [
    "dist/apps/cli",
    "dist/apps/web",
    "dist/packages",
    "dist/src",
    "dist/main.js",
    "docs",
    "schemas",
    "packages/geography/data/continents.provenance.md",
    "COPYING",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-compat-build.mjs",
    "chess:build": "rm -rf apps/chess-desktop/dist-electron && vite build --config apps/chess-desktop/vite.config.ts && tsc -p apps/chess-desktop/tsconfig.json",
    "chess:dev": "node scripts/chess-dev.mjs",
    "chess:test": "npm run build && node --test test/chess-core.test.mjs test/chess-desktop.test.mjs",
    "content:catalogue": "npm run build && node dist/packages/core/content-package-catalogue-cli.js",
    "dev": "tsc --outDir .dev-dist && node .dev-dist/main.js",
    "generate-content-package": "npm run build && node dist/packages/core/content-package-generator-cli.js",
    "prepack": "npm run build",
    "pretest": "npm run build",
    "start": "node dist/main.js",
    "sync-linguistic-terminology": "node scripts/sync-linguistic-terminology.mjs",
    "test": "node --test --test-concurrency=1 test/*.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
