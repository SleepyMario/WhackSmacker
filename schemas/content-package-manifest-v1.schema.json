{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sleepymario.com/whacksmacker/schemas/content-package-manifest-v1.schema.json",
  "title": "WhackSmacker Content Package Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packageFormatVersion",
    "packageId",
    "packageVersion",
    "displayName",
    "description",
    "contentType",
    "contentSchemaVersion",
    "minimumWhackSmackerVersion",
    "source",
    "generatedAt",
    "generator",
    "entryPoints",
    "files"
  ],
  "properties": {
    "packageFormatVersion": {
      "const": 1
    },
    "packageId": {
      "$ref": "#/$defs/packageId"
    },
    "packageVersion": {
      "$ref": "#/$defs/semver"
    },
    "displayName": {
      "$ref": "#/$defs/localizedContent"
    },
    "description": {
      "$ref": "#/$defs/localizedContent"
    },
    "contentType": {
      "oneOf": [
        {
          "enum": [
            "language-curriculum",
            "core-review",
            "linguistic-terminology",
            "mathematics-curriculum",
            "geography-dataset",
            "chess-content",
            "demonstration"
          ]
        },
        {
          "$ref": "#/$defs/packageId"
        }
      ]
    },
    "contentSchemaVersion": {
      "$ref": "#/$defs/semver"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["reading-curriculum", "core-review", "technical"] }
    },
    "relatedPackageIds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/packageId" }
    },
    "minimumWhackSmackerVersion": {
      "$ref": "#/$defs/semver"
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 2
      },
      "uniqueItems": true
    },
    "subjects": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "$ref": "#/$defs/gitCommit"
        },
        "path": {
          "$ref": "#/$defs/safePath"
        },
        "dirty": {
          "type": "boolean"
        }
      }
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "commit": {
          "$ref": "#/$defs/gitCommit"
        }
      }
    },
    "entryPoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "mediaType", "path", "role"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "mediaType": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "$ref": "#/$defs/safePath"
          },
          "role": {
            "enum": ["primary", "index", "search-index", "metadata"]
          }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["packageId", "version"],
        "properties": {
          "packageId": {
            "$ref": "#/$defs/packageId"
          },
          "version": {
            "type": "string",
            "pattern": "^(?:[<>=~^]*[0-9]+\\.[0-9]+\\.[0-9]+)(?:\\s+[<>=~^]*[0-9]+\\.[0-9]+\\.[0-9]+)*$"
          },
          "optional": {
            "type": "boolean"
          }
        }
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "mediaType", "size", "sha256"],
        "properties": {
          "path": {
            "$ref": "#/$defs/safePath"
          },
          "mediaType": {
            "type": "string",
            "minLength": 1
          },
          "size": {
            "type": "integer",
            "minimum": 0
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "spdx": {
          "type": ["string", "null"]
        },
        "name": {
          "type": ["string", "null"]
        },
        "path": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/safePath"
            }
          ]
        }
      }
    },
    "homepage": {
      "type": "string"
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "localizedContent": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "minLength": 1 },
          "additionalProperties": { "type": "string", "minLength": 1 }
        }
      ]
    },
    "packageId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*(?:\\.[a-z0-9][a-z0-9-]*){2,}$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "gitCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "safePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          {
            "pattern": "^/"
          },
          {
            "pattern": "\\\\"
          },
          {
            "pattern": "(^|/)\\.\\.($|/)"
          },
          {
            "pattern": "(^|/)\\.($|/)"
          },
          {
            "pattern": "//"
          }
        ]
      }
    }
  }
}
