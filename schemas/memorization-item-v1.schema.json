{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sleepymario.com/whacksmacker/schemas/memorization-item-v1.schema.json",
  "title": "WhackSmacker Memorization Item v1",
  "oneOf": [
    {
      "$ref": "#/$defs/item"
    },
    {
      "$ref": "#/$defs/collection"
    }
  ],
  "$defs": {
    "collection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "items"],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/item"
          }
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "id", "kind", "prompt", "answer"],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "id": {
          "$ref": "#/$defs/safeId"
        },
        "kind": {
          "enum": ["basic-card", "cloze", "vocabulary", "sentence", "concept"]
        },
        "prompt": {
          "$ref": "#/$defs/contentBlock"
        },
        "answer": {
          "$ref": "#/$defs/contentBlock"
        },
        "hints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/localizedContent"
          }
        },
        "notes": {
          "$ref": "#/$defs/localizedContent"
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "uniqueItems": true
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path"],
          "properties": {
            "path": {
              "$ref": "#/$defs/safePath"
            },
            "anchor": {
              "type": "string",
              "minLength": 1
            },
            "title": {
              "$ref": "#/$defs/localizedContent"
            }
          }
        },
        "language": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "target": {
              "type": "string",
              "minLength": 2
            },
            "base": {
              "type": "string",
              "minLength": 2
            },
            "script": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "difficulty": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "level": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10
            },
            "label": {
              "$ref": "#/$defs/localizedContent"
            }
          }
        },
        "createdAt": {
          "$ref": "#/$defs/timestamp"
        },
        "updatedAt": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "contentBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": {
          "$ref": "#/$defs/localizedContent"
        },
        "plainText": {
          "$ref": "#/$defs/localizedContentAllowEmpty"
        },
        "language": {
          "type": "string",
          "minLength": 2
        },
        "mediaType": {
          "enum": ["text/plain", "text/markdown"]
        }
      }
    },
    "localizedContent": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "minLength": 1 },
          "additionalProperties": { "type": "string", "minLength": 1 }
        }
      ]
    },
    "localizedContentAllowEmpty": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "minLength": 1 },
          "additionalProperties": { "type": "string" }
        }
      ]
    },
    "safeId": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9._/-]*[a-z0-9])?$"
    },
    "safePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*//)[^\\u0000]+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    }
  }
}
