{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sleepymario.com/whacksmacker/schemas/content-package-catalogue-v1.schema.json",
  "title": "WhackSmacker Content Package Catalogue v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["catalogueFormatVersion", "catalogueId", "displayName", "description", "generatedAt", "packages"],
  "properties": {
    "catalogueFormatVersion": {
      "const": 1
    },
    "catalogueId": {
      "$ref": "#/$defs/packageId"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "packageId",
          "packageVersion",
          "displayName",
          "description",
          "contentType",
          "contentSchemaVersion",
          "minimumWhackSmackerVersion",
          "source",
          "package"
        ],
        "properties": {
          "packageId": {
            "$ref": "#/$defs/packageId"
          },
          "packageVersion": {
            "$ref": "#/$defs/semver"
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "contentType": {
            "type": "string",
            "minLength": 1
          },
          "contentSchemaVersion": {
            "$ref": "#/$defs/semver"
          },
          "minimumWhackSmackerVersion": {
            "$ref": "#/$defs/semver"
          },
          "languages": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 2
            },
            "uniqueItems": true
          },
          "subjects": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "source": {
            "type": "object",
            "additionalProperties": false,
            "required": ["repository", "commit"],
            "properties": {
              "repository": {
                "type": "string",
                "minLength": 1
              },
              "commit": {
                "$ref": "#/$defs/gitCommit"
              },
              "path": {
                "$ref": "#/$defs/safePath"
              },
              "dirty": {
                "type": "boolean"
              }
            }
          },
          "package": {
            "type": "object",
            "additionalProperties": false,
            "required": ["url", "mediaType", "size", "sha256"],
            "properties": {
              "url": {
                "type": "string",
                "pattern": "^(file|https)://.+"
              },
              "mediaType": {
                "type": "string",
                "minLength": 1
              },
              "size": {
                "type": "integer",
                "minimum": 0
              },
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              }
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["packageId", "version"],
              "properties": {
                "packageId": {
                  "$ref": "#/$defs/packageId"
                },
                "version": {
                  "type": "string",
                  "pattern": "^(?:[<>=~^]*[0-9]+\\.[0-9]+\\.[0-9]+)(?:\\s+[<>=~^]*[0-9]+\\.[0-9]+\\.[0-9]+)*$"
                },
                "optional": {
                  "type": "boolean"
                }
              }
            }
          },
          "license": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "spdx": {
                "type": ["string", "null"]
              },
              "name": {
                "type": ["string", "null"]
              },
              "path": {
                "type": ["string", "null"]
              }
            }
          },
          "homepage": {
            "type": "string"
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        }
      }
    }
  },
  "$defs": {
    "packageId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*(?:\\.[a-z0-9][a-z0-9-]*){2,}$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "gitCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "safePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*//)[^\\u0000]+$"
    }
  }
}
