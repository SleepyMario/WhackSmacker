{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whacksmacker.com/schemas/canonical-cast-v1.schema.json",
  "title": "WhackSmacker canonical cast with active-cast progression",
  "type": "object",
  "required": ["schemaVersion", "cast", "deckPersonPool", "activeCast"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "cast": {
      "type": "array",
      "minItems": 30,
      "maxItems": 30,
      "items": {
        "type": "object",
        "required": ["id", "displayName", "age", "origin", "residence", "dailyRole", "relationshipStatus", "household", "relevantFamily", "background", "interests", "personality", "castRelationships", "recurringContexts", "continuityNotes"],
        "properties": { "id": { "type": "string", "minLength": 1 } }
      }
    },
    "deckPersonPool": { "type": "array", "minItems": 30, "maxItems": 30, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "activeCast": {
      "type": "object",
      "required": ["schemaVersion", "progression"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "progression": { "type": "array", "minItems": 30, "maxItems": 30, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "legacyMigration": {
          "type": "object",
          "required": ["status", "note"],
          "properties": { "status": { "const": "pending" }, "note": { "type": "string", "minLength": 1 } },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
